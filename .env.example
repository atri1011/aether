PORT=8787
NODE_ENV=production
CACHE_DIR=/app/.cache/aether

# Access gate (recommended on public VPS)
SITE_PASSWORD=change-me-strong-passphrase
AUTH_SECRET=generate-with-openssl-rand-hex-32
AUTH_TTL_HOURS=168
AUTH_SECURE_COOKIE=1

# Optional upstreams
# RECOMBEE_PUBLIC_TOKEN=
# MISS_DETAIL_BASES=https://missav.ai,https://missav.ws
# MISS_LANG=zh
