PORT=8787
NODE_ENV=production
CACHE_DIR=/app/.cache/aether

# Access gate (recommended on public VPS)
SITE_PASSWORD=change-me-strong-passphrase
AUTH_SECRET=generate-with-openssl-rand-hex-32
AUTH_TTL_HOURS=168
AUTH_SECURE_COOKIE=1

# Cache L1 / GC (OPT-02)
# CACHE_L1_MAX=500
# CACHE_MAX_MB=512
# CACHE_GC_INTERVAL_MS=3600000

# Feature flags (1=on, 0=off)
# SCRAPE_WORKER=1
# HLS_STREAMING=1
# VIDEO_LAZY_STREAM=1
# RATE_LIMIT=1

# Workers
# SCRAPE_PORT=18791
# SCRAPE_CONCURRENCY=2
# MEDIA_PORT=18790

# Security (OPT-04)
# TRUST_PROXY=1
# CORS_ORIGINS=https://ljl.050415.xyz
# RATE_LIMIT_GENERAL=120
# RATE_LIMIT_SCRAPE=30
# RATE_LIMIT_HLS=300
# ADMIN_TOKEN=

# Recombee deep-page cap (OPT-14)
# RECOMBEE_MAX_COUNT=96

# Optional upstreams
# RECOMBEE_PUBLIC_TOKEN=
# MISS_DETAIL_BASES=https://missav.ai,https://missav.ws
# MISS_LANG=zh
